extends "package://pkg.pkl-lang.org/pkl-k8s/k8s@1.4.1#/K8sResource.pkl"

import "package://pkg.pkl-lang.org/pkl-k8s/k8s@1.4.1#/api/core/v1/LocalObjectReference.pkl"
import "package://pkg.pkl-lang.org/pkl-k8s/k8s@1.4.1#/api/core/v1/PersistentVolumeClaimSpec.pkl"
import "package://pkg.pkl-lang.org/pkl-k8s/k8s@1.4.1#/apimachinery/pkg/apis/meta/v1/ObjectMeta.pkl"

fixed apiVersion = "postgresql.cnpg.io/v1"
fixed kind = "ScheduledBackup"

metadata: ObjectMeta
spec: ScheduledBackupSpec

class ScheduledBackupSpec {
  suspend: Boolean?
  immediate: Boolean?
  schedule: String
  cluster: LocalObjectReference
  backupOwnerReference: ("none" | "self" | "cluster")?
  target: String?
  method: ("volumeSnapshot" | "barmanObjectStore" | "plugin")?
  pluginConfiguration: BackupPluginConfiguration?
  online: Boolean?
  onlineConfiguration: OnlineConfiguration?
}

class BackupPluginConfiguration {
  name: String
  parameters: Mapping<String, String>?
}

class OnlineConfiguration {
  waitForArchive: Boolean?
  immediateCheckpoint: Boolean?
}
