import "package://pkg.pkl-lang.org/pkl-k8s/k8s@1.4.1#/K8sResource.pkl"

import "../deploy/Deploy.pkl"

app =
  new Deploy {
    name = "atuin"
    namespace = "atuin"
    image = "ghcr.io/atuinsh/atuin:latest"
    args {
      "start"
    }
    ports {
      new {
        containerPort = 8888
        svcPort = 80
        name = "http"
      }
    }
    volumes {
      new {
        name = "atuin-config-pvc"
        size = 128.mib
        containerPath = "/config"
      }
    }
    resourceRequirements {
      limits {
        ["cpu"] = "250m"
        ["memory"] = 1.gib
      }
      requests {
        ["cpu"] = "250m"
        ["memory"] = 1.gib
      }
    }
    livenessProbe {
      path = "/"
      port = "http"
    }
    startupProbe {
      path = "/"
      port = "http"
    }
    pgDb {
      storageClass = "local-path-ssd"
      envMapping {
        uri = "ATUIN_DB_URI"
      }
    }
    env {
      ["ATUIN_HOST"] = "0.0.0.0"
      ["ATUIN_PORT"] = "8888"
      ["ATUIN_OPEN_REGISTRATION"] = "true"
    }
  }.resources

output {
  value = app
  renderer = (K8sResource.output.renderer as YamlRenderer) {
    isStream = true
  }
}
