import "package://pkg.pkl-lang.org/pkl-k8s/k8s@1.4.1#/K8sResource.pkl"

import "../deploy/Deploy.pkl"

actual =
  new Deploy {
    name = "actual"
    image = "actualbudget/actual-server:26.6.0"
    ports {
      new {
        containerPort = 5006
        svcPort = 80
        name = "http"
      }
    }
    volumes {
      new {
        name = "actual-pvc"
        size = 5.gib
        containerPath = "/data"
        accessMode = "ReadWriteOnce"
      }
    }
    resourceRequirements {
      limits {
        ["cpu"] = "500m"
        ["memory"] = 512.mib
      }
      requests {
        ["cpu"] = "100m"
        ["memory"] = 128.mib
      }
    }
    livenessProbe {
      path = "/"
      port = "http"
    }
    startupProbe {
      path = "/"
      port = "http"
    }
    env {
      ["ACTUAL_PORT"] = "5006"
    }
  }.resources

output {
  value = actual
  renderer = (K8sResource.output.renderer as YamlRenderer) {
    isStream = true
  }
}
