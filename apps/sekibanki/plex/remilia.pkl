import "package://pkg.pkl-lang.org/pkl-k8s/k8s@1.4.1#/K8sResource.pkl"

import "plex.pkl"

app =
  new plex {
    user = "remilia"
    mediaHostPath = "/var/mnt/yuyuko/media"
    mediaContainerPath = "/data"
  }
    .deploy
    .resources

output {
  value = app
  renderer = (K8sResource.output.renderer as YamlRenderer) {
    isStream = true
  }
}
